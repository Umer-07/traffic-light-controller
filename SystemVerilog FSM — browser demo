<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Traffic Light Controller — FSM Demo</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Syne:wght@400;700;800&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:       #0a0a0f;
    --surface:  #12121a;
    --surface2: #1a1a26;
    --border:   #2a2a3a;
    --muted:    #555570;
    --text:     #e8e8f0;
    --text2:    #9090b0;
    --red:      #ff3b3b;
    --red-dim:  #3a1010;
    --amber:    #ffaa00;
    --amber-dim:#2e2000;
    --green:    #00dd88;
    --green-dim:#002e1e;
    --walk:     #00aaff;
    --walk-dim: #001e30;
    --font-mono: 'JetBrains Mono', monospace;
    --font-display: 'Syne', sans-serif;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-mono);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40px 20px 60px;
  }

  header {
    text-align: center;
    margin-bottom: 48px;
  }

  header h1 {
    font-family: var(--font-display);
    font-size: clamp(22px, 4vw, 36px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 6px;
  }

  header p {
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 24px;
    width: 100%;
    max-width: 860px;
    align-items: start;
  }

  @media (max-width: 600px) {
    .layout { grid-template-columns: 1fr; }
  }

  /* ---- Traffic light housing ---- */
  .housing {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 24px 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .housing-label {
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .bulb-wrap {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }

  .bulb {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    transition: background 0.25s, box-shadow 0.25s;
  }

  .bulb.red   { background: var(--red-dim);   }
  .bulb.amber { background: var(--amber-dim); }
  .bulb.green { background: var(--green-dim); }

  .bulb.red.on   { background: var(--red);   box-shadow: 0 0 28px var(--red),   0 0 6px var(--red); }
  .bulb.amber.on { background: var(--amber); box-shadow: 0 0 28px var(--amber), 0 0 6px var(--amber); }
  .bulb.green.on { background: var(--green); box-shadow: 0 0 28px var(--green), 0 0 6px var(--green); }

  .divider {
    width: 1px;
    height: 1px;
    background: var(--border);
    margin: 4px 0;
    align-self: stretch;
    border-top: 1px solid var(--border);
  }

  .walk-sign {
    width: 64px;
    height: 40px;
    border-radius: 8px;
    background: var(--walk-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    letter-spacing: 0.12em;
    color: #223344;
    font-weight: 700;
    transition: background 0.25s, color 0.25s, box-shadow 0.25s;
  }

  .walk-sign.on {
    background: var(--walk);
    color: #001830;
    box-shadow: 0 0 20px var(--walk), 0 0 6px var(--walk);
    animation: walkBlink 0.9s step-end infinite;
  }

  @keyframes walkBlink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.5; }
  }

  /* ---- Right panel ---- */
  .panel {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px 24px;
  }

  .card-label {
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 12px;
  }

  /* State display */
  .state-name {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -0.02em;
    transition: color 0.25s;
    margin-bottom: 4px;
  }

  .state-desc {
    font-size: 12px;
    color: var(--text2);
    line-height: 1.6;
  }

  /* Timer bar */
  .timer-track {
    height: 4px;
    background: var(--surface2);
    border-radius: 2px;
    margin-top: 16px;
    overflow: hidden;
  }

  .timer-fill {
    height: 4px;
    border-radius: 2px;
    width: 0%;
    transition: width 0.18s linear, background 0.3s;
  }

  .timer-meta {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--muted);
    margin-top: 6px;
  }

  /* FSM log */
  .log-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 140px;
    overflow-y: auto;
  }

  .log-list::-webkit-scrollbar { width: 4px; }
  .log-list::-webkit-scrollbar-track { background: transparent; }
  .log-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .log-entry {
    font-size: 11px;
    color: var(--text2);
    padding: 4px 8px;
    border-radius: 6px;
    background: var(--surface2);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .log-entry.new {
    color: var(--text);
    border-left: 2px solid currentColor;
  }

  .log-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Controls */
  .controls {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .btn {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    padding: 10px 18px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--text);
    cursor: pointer;
    letter-spacing: 0.05em;
    transition: background 0.15s, border-color 0.15s, transform 0.1s;
  }

  .btn:hover   { background: #22223a; border-color: #44446a; }
  .btn:active  { transform: scale(0.97); }

  .btn.primary {
    background: #1a2a1a;
    border-color: #2a4a2a;
    color: var(--green);
  }

  .btn.primary:hover { background: #1f341f; border-color: var(--green); }

  .btn.ped {
    background: #001830;
    border-color: #003050;
    color: var(--walk);
  }

  .btn.ped:hover  { border-color: var(--walk); }
  .btn.ped.active-ped { border-color: var(--walk); background: #002244; box-shadow: 0 0 10px #00aaff44; }

  .speed-row {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 11px;
    color: var(--muted);
  }

  .speed-row input[type=range] {
    flex: 1;
    accent-color: var(--green);
  }

  /* ped latch badge */
  .ped-badge {
    display: inline-block;
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 20px;
    background: #001830;
    color: var(--walk);
    border: 1px solid #003060;
    opacity: 0;
    transition: opacity 0.3s;
    margin-left: 8px;
    vertical-align: middle;
  }

  .ped-badge.visible { opacity: 1; }
</style>
</head>
<body>

<header>
  <h1>Traffic Light Controller</h1>
  <p>SystemVerilog FSM &mdash; browser demo</p>
</header>

<div class="layout">

  <!-- Left: traffic light -->
  <div class="housing">
    <span class="housing-label">Car signal</span>
    <div class="bulb-wrap">
      <div class="bulb red on" id="b-red"></div>
      <div class="bulb amber"  id="b-amber"></div>
      <div class="bulb green"  id="b-green"></div>
    </div>
    <div class="divider"></div>
    <span class="housing-label">Pedestrian</span>
    <div class="walk-sign" id="b-walk">WALK</div>
  </div>

  <!-- Right: info + controls -->
  <div class="panel">

    <!-- State -->
    <div class="card">
      <div class="card-label">Current state</div>
      <div class="state-name" id="state-name" style="color:var(--red)">S_RED</div>
      <div class="state-desc" id="state-desc">Cars stopped. Waiting for timer to expire.</div>
      <div class="timer-track">
        <div class="timer-fill" id="timer-fill" style="background:var(--red)"></div>
      </div>
      <div class="timer-meta">
        <span id="timer-tick">tick 0</span>
        <span id="timer-max">/ 10</span>
      </div>
    </div>

    <!-- Controls -->
    <div class="card">
      <div class="card-label">Controls</div>
      <div class="controls" style="margin-bottom:14px;">
        <button class="btn primary" id="btn-run"  onclick="toggleRun()">&#9654; Run</button>
        <button class="btn"         id="btn-step" onclick="stepOnce()">Step</button>
        <button class="btn"         onclick="resetSim()">Reset</button>
        <button class="btn ped"     id="btn-ped"  onclick="pressPed()">
          Ped button <span class="ped-badge" id="ped-badge">LATCHED</span>
        </button>
      </div>
      <div class="speed-row">
        <span>Speed</span>
        <input type="range" min="1" max="10" value="4" step="1" id="speed-slider" oninput="setSpeed(this.value)">
        <span id="speed-label">4×</span>
      </div>
    </div>

    <!-- Log -->
    <div class="card">
      <div class="card-label">FSM event log</div>
      <ul class="log-list" id="log-list"></ul>
    </div>

  </div>
</div>

<script>
  const TIMES  = { S_RED:10, S_GREEN:12, S_YELLOW:4, S_WALK:8 };
  const COLORS = { S_RED:'var(--red)', S_GREEN:'var(--green)', S_YELLOW:'var(--amber)', S_WALK:'var(--walk)' };
  const DESCS  = {
    S_RED:    'Cars stopped. Waiting for timer to expire.',
    S_GREEN:  'Cars moving. Pedestrian requests are latched.',
    S_YELLOW: 'Slowing down. Checking pedestrian request.',
    S_WALK:   'Pedestrians crossing. Cars held at red.'
  };
  const NEXT = {
    S_RED:    () => 'S_GREEN',
    S_GREEN:  () => 'S_YELLOW',
    S_YELLOW: () => pedLatched ? 'S_WALK' : 'S_RED',
    S_WALK:   () => 'S_RED'
  };
  const DOT_COLORS = { S_RED:'#ff3b3b', S_GREEN:'#00dd88', S_YELLOW:'#ffaa00', S_WALK:'#00aaff' };

  let state      = 'S_RED';
  let tick       = 0;
  let pedLatched = false;
  let running    = false;
  let intervalId = null;
  let speedMs    = 250;

  function setSpeed(v) {
    document.getElementById('speed-label').textContent = v + '×';
    speedMs = Math.round(1000 / v);
    if (running) { clearInterval(intervalId); intervalId = setInterval(stepOnce, speedMs); }
  }

  function toggleRun() {
    running = !running;
    document.getElementById('btn-run').textContent = running ? '⏸ Pause' : '▶ Run';
    if (running) {
      intervalId = setInterval(stepOnce, speedMs);
    } else {
      clearInterval(intervalId);
    }
  }

  function resetSim() {
    running = false;
    clearInterval(intervalId);
    document.getElementById('btn-run').textContent = '▶ Run';
    state = 'S_RED'; tick = 0; pedLatched = false;
    document.getElementById('log-list').innerHTML = '';
    document.getElementById('ped-badge').classList.remove('visible');
    document.getElementById('btn-ped').classList.remove('active-ped');
    render();
    addLog('Reset → S_RED', 'S_RED');
  }

  function pressPed() {
    if (state === 'S_WALK') { addLog('Already in WALK — ignored', state); return; }
    if (pedLatched) { addLog('Already latched', state); return; }
    pedLatched = true;
    document.getElementById('ped-badge').classList.add('visible');
    document.getElementById('btn-ped').classList.add('active-ped');
    addLog('Ped button pressed — latched', state);
  }

  function stepOnce() {
    tick++;
    const limit = TIMES[state];
    if (tick >= limit) {
      const prev = state;
      state = NEXT[state]();
      tick  = 0;
      if (state === 'S_WALK') {
        pedLatched = false;
        document.getElementById('ped-badge').classList.remove('visible');
        document.getElementById('btn-ped').classList.remove('active-ped');
      }
      addLog(prev + ' → ' + state, state);
    }
    render();
  }

  function render() {
    const s = state;
    const isRed    = s === 'S_RED'    || s === 'S_WALK';
    const isAmber  = s === 'S_YELLOW';
    const isGreen  = s === 'S_GREEN';
    const isWalk   = s === 'S_WALK';

    document.getElementById('b-red').classList.toggle('on', isRed);
    document.getElementById('b-amber').classList.toggle('on', isAmber);
    document.getElementById('b-green').classList.toggle('on', isGreen);
    document.getElementById('b-walk').classList.toggle('on', isWalk);

    document.getElementById('state-name').textContent = s;
    document.getElementById('state-name').style.color = DOT_COLORS[s];
    document.getElementById('state-desc').textContent = DESCS[s];

    const pct = Math.round((tick / TIMES[s]) * 100);
    document.getElementById('timer-fill').style.width = pct + '%';
    document.getElementById('timer-fill').style.background = DOT_COLORS[s];
    document.getElementById('timer-tick').textContent = 'tick ' + tick;
    document.getElementById('timer-max').textContent  = '/ ' + (TIMES[s] - 1);
  }

  function addLog(msg, forState) {
    const ul   = document.getElementById('log-list');
    const li   = document.createElement('li');
    li.className = 'log-entry new';
    li.style.borderLeftColor = DOT_COLORS[forState] || '#555';
    const dot  = document.createElement('div');
    dot.className = 'log-dot';
    dot.style.background = DOT_COLORS[forState] || '#555';
    const txt  = document.createElement('span');
    txt.textContent = msg;
    li.appendChild(dot);
    li.appendChild(txt);
    ul.insertBefore(li, ul.firstChild);
    setTimeout(() => li.classList.remove('new'), 800);
    while (ul.children.length > 12) ul.removeChild(ul.lastChild);
  }

  render();
  addLog('Power on → S_RED', 'S_RED');
</script>
</body>
</html>
